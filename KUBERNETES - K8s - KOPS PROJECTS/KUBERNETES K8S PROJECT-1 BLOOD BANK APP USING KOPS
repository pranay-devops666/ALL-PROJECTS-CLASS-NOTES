        stage ("Push") {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'dockerhub') {
                        sh 'docker push pranay419/bloodyapp:dbimage'
                        sh 'docker push pranay419/bloodyapp:appimage'
                    }    
                }
            }
        }
    }
}


